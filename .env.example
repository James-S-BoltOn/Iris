# ── Server ──
PORT=3000

# ── Database ──
DATABASE_PATH=iris.db

# ── Security ──
# Shared secret for ElevenLabs webhook validation.
# Set this in ElevenLabs console under agent > webhook settings.
# If unset, webhook accepts all requests (dev mode only).
WEBHOOK_SECRET=your_webhook_secret_here

# Bearer token for accessing GET /calls endpoints.
# If unset, call log API is disabled (returns 401).
CALLS_API_TOKEN=your_calls_api_token_here

# ── Email Notifications ──
# Gmail example: host=smtp.gmail.com, port=587, user=you@gmail.com, pass=app-password
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password_here
SMTP_FROM=iris@yourdomain.com
NOTIFY_EMAIL=james@example.com

# ── ElevenLabs ──
# Webhook URL for ElevenLabs console:
#   https://iris-assistant-aged-violet-6602.fly.dev/webhook/call-complete
# ELEVENLABS_AGENT_ID=agent_0801kmxx540qe1a9w35mb436qe90
